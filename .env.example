# Database
DATABASE_URL=postgresql://user:pass@db.xxx.supabase.co:5432/postgres

# Supabase Auth
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key          # Server only, never expose to client

# GitHub OAuth (direct — not Supabase-hosted callback)
# Create a SEPARATE OAuth app for local dev so prod credentials stay isolated:
#   https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Application name: OnchainAI Local (or similar)
#   Homepage URL: http://localhost:3000
#   Authorization callback URL: http://localhost:3000/auth/callback
# Copy Client ID and generate a Client secret into the vars below.
GITHUB_CLIENT_ID=your-local-dev-client-id
GITHUB_CLIENT_SECRET=your-local-dev-client-secret   # Server only
# Optional override when callback URL differs from SIWX_DOMAIN + PORT default.
# Must exactly match a URL registered on the SAME GitHub OAuth app as GITHUB_CLIENT_ID.
# Local default (when unset): http://localhost:3000/auth/callback
# Production (Railway): https://www.onchain-ai.xyz/auth/callback
# Verify: ./scripts/local-auth-check.sh
# GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# Google OAuth (optional — sign-in is inert when unset; server still boots)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs must include the callback below.
# Local default (when unset): http://localhost:3000/auth/google/callback
# Production (Railway): https://www.onchain-ai.xyz/auth/google/callback
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret   # Server only
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# SIWX (Wallet Auth)
SIWX_DOMAIN=localhost:3000                      # Local dev; prod uses SIWX_DOMAIN_PROD via deploy script
SIWX_SESSION_TTL=86400                          # 24h in seconds
JWT_SECRET=generate-32-byte-random-string       # Server only

# Operator admin (GitHub OAuth logins — comma-separated, case-insensitive)
# Grants profiles.is_admin=true on login. Does not auto-promote wallet/email users.
# ADMIN_GITHUB_LOGINS=Coinyak

# GitHub API (Crawler)
GITHUB_API_TOKEN=your-github-personal-access-token  # Server only, for star sync

# x402 — referral config is per-tool / admin site_settings (not client-exposed).
# Two paid axes, both facilitator verify/settle only (no custody):
#   K2      check_endpoint_health — OnchainAI-owned premium, uses X402_* below
#   Axis B  compare_tools / export_toolkit — operator-toggled via admin site_settings (mcp_premium_*)
# Builder Code: register app at https://dashboard.base.org → Settings → Builder Codes → set site_settings.x402_builder_code
# Bazaar index: CDP Facilitator settle on paid route — https://docs.cdp.coinbase.com/x402/bazaar
# BASE_DEV_API_KEY=bdev_...   # Server only — Base Dashboard notifications API (optional)
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402  # prod (Base); testnet: https://x402.org/facilitator
# X402_PAY_TO_ADDRESS=0xYourWalletAddress            # OnchainAI payout wallet — required for premium K2
# X402_NETWORK=eip155:8453                           # Base mainnet; testnet: eip155:84532
# X402_PREMIUM_PRICE_USD=$0.001                        # check_endpoint_health per-call price
# CDP_API_KEY_NAME=...                                 # optional — CDP facilitator auth (prod)
# CDP_API_KEY_PRIVATE_KEY=...                          # optional — CDP facilitator auth (prod)
# ONCHAINAI_MCP_X402_DEV_ACCEPT=1                    # dev only: skip facilitator verify for MCP premium (ignored in prod)

# Server
PORT=3000
RUST_LOG=info

# CORS — comma-separated browser origins for split Vercel frontend (optional)
# FRONTEND_ORIGIN=https://www.onchain-ai.xyz,https://your-app.vercel.app

# Production deploy (deploy-railway.sh maps *_PROD → Railway; local GITHUB_* stay for dev)
SIWX_DOMAIN_PROD=www.onchain-ai.xyz
# GITHUB_CLIENT_ID_PROD=your-prod-oauth-client-id
# GITHUB_CLIENT_SECRET_PROD=your-prod-oauth-client-secret
# GITHUB_REDIRECT_URI_PROD=https://www.onchain-ai.xyz/auth/callback

# Database pool (app default 5 when unset; deploy-railway.sh syncs 10 to Railway)
DATABASE_MAX_CONNECTIONS=5

# Runtime / local dev (restart-dev.sh and Dockerfile set defaults)
SKIP_CRAWLER=1                                  # Skip crawler scheduler at startup
RUST_MIN_STACK=8388608                          # Tokio worker stack (Linux containers)
LEPTOS_SITE_ROOT=target/site                    # Served static + hydration assets

# Railway operator (optional)
RAILWAY_SERVICE=onchainai

# Test (local Postgres — not loaded by Config::from_env)
DATABASE_URL_TEST=postgresql://user@localhost:5432/onchainai_test
