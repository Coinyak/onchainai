# Database
DATABASE_URL=postgresql://user:pass@db.xxx.supabase.co:5432/postgres

# Supabase Auth
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key          # Server only, never expose to client

# GitHub OAuth
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret         # Server only

# SIWX (Wallet Auth)
SIWX_DOMAIN=onchainai.xyz
SIWX_SESSION_TTL=86400                          # 24h in seconds
JWT_SECRET=generate-32-byte-random-string       # Server only

# GitHub API (Crawler)
GITHUB_API_TOKEN=your-github-personal-access-token  # Server only, for star sync

# x402
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAY_TO_ADDRESS=0xYourWalletAddress

# Server
PORT=3000
RUST_LOG=info

# Test
SUPABASE_URL_TEST=postgresql://love@localhost:5432/onchainai_test
